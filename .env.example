# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Dashboard label: "Publishable key" (same as legacy anon key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Dashboard label: "Secret key" — server only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# App
APP_ENV=development
APP_BASE_URL=http://localhost:3000

# Security — generate a long random string for production
TRACK_CODE_PEPPER=

# First admin bootstrap (Sprint 2+)
ADMIN_BOOTSTRAP_EMAIL=
